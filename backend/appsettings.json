{
  "ConnectionStrings": {
    "DefaultConnection": "${DB_CONNECTION_STRING}"
  },
  "Cloudinary": {
    "CloudName": "${CLOUDINARY_CLOUD_NAME}",
    "ApiKey": "${CLOUDINARY_API_KEY}",
    "ApiSecret": "${CLOUDINARY_API_SECRET}"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "GreenWeave",
    "Audience": "GreenWeave-Users",
    "ExpirationMinutes": "1440"
  },
  "SendGrid": {
    "ApiKey": "${SENDGRID_API_KEY}",
    "FromEmail": "no-reply@greenweave.vn",
    "FromName": "GreenWeave Store"
  },
  "Shipping": {
    "Environment": "Production",
    "ViettelPost": {
      "BaseUrl": "https://partner.viettelpost.vn",
      "Token": "${VIETTELPOST_TOKEN}",
      "PrintToken": "${VIETTELPOST_PRINT_TOKEN}",
      "WebhookSecret": "${VIETTELPOST_WEBHOOK_SECRET}",
      "PartnerID": "10128074",
      "TimeoutSeconds": 120,
      "IsEnabled": true,
      "DefaultServiceId": "VCN",
      "_comment_deprecated": "DefaultPickupAddress is deprecated - now using Warehouse management system",
      "DefaultPickupAddress": {
        "Name": "GreenWeave Store",
        "Phone": "0359994361",
        "AddressDetail": "19 ĐƯỜNG Định Bộ Lĩnh, P.Hải Cảng",
        "ProvinceId": 40,
        "DistrictId": 464,
        "WardId": 8541,
        "ProvinceName": "Bình Định",
        "DistrictName": "TP.Qui Nhơn",
        "WardName": "P.Hải Cảng"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
    "AllowedHosts": "*",
    "Order": {
      "AutoConfirmOnPayment": false,
      "AutoConfirmPaymentMethods": [ "BankTransfer", "PayOS" ]
    },
  "PayOS": {
    "ClientId": "${PAYOS_CLIENT_ID}",
    "ApiKey": "${PAYOS_API_KEY}",
    "ChecksumKey": "${PAYOS_CHECKSUM_KEY}"
   
  },
  "Gemini": {
    "ApiKey": "${GEMINI_API_KEY}",
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta",
    "Model": "gemini-2.0-flash-exp",
    "MaxTokens": 8192,
    "Temperature": 0.7,
    "TimeoutSeconds": 60
  }
  
}


