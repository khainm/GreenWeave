
{
  "DetailedErrors": false,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "GreenWeave-API",
    "Audience": "GreenWeave-Users",
    "ExpirationMinutes": "60"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/auth/register",
        "Period": "1h",
        "Limit": 3
      },
      {
        "Endpoint": "*/api/*",
        "Period": "1m",
        "Limit": 100
      }
    ],
    "EndpointWhitelist": [
      "GET:/health",
      "GET:/"
    ]
  },
  "SendGrid": {
    "ApiKey": "",
    "FromEmail": "no-reply@greenweave.vn",
    "FromName": "GreenWeave Store"
  },
  "Shipping": {
    "Environment": "Production",
    "ViettelPost": {
      "BaseUrl": "https://partner.viettelpost.vn",
      "Token": "",
      "PrintToken": "",
      "WebhookSecret": "",
      "PartnerID": "10128074",
      "TimeoutSeconds": 30,
      "IsEnabled": true
    }
  },
  "PayOS": {
    "ClientId": "${PAYOS_CLIENT_ID}",
    "ApiKey": "${PAYOS_API_KEY}",
    "ChecksumKey": "${PAYOS_CHECKSUM_KEY}",
    "Endpoint": "${PAYOS_ENDPOINT}"
  },
  "Order": {
    "AutoConfirmOnPayment": true,
    "AutoConfirmPaymentMethods": ["PayOS", "BankTransfer"],
    "AutoConfirmOnCreate": true,
    "AutoConfirmCreateMethods": ["CashOnDelivery"]
  }
}
  
  
 



